{
  "name": "planning-poker",
  "private": true,
  "version": "1.0.0",
  "description": "Planning Poker Chrome Extension + Backend",
  "scripts": {
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter extension dev\"",
    "build": "pnpm --filter shared-types build && pnpm --filter server build && pnpm --filter extension build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
