NODE_ENV=development
PORT=3000

# Path for the SQLite database file
DB_PATH=./data/poker.db

# Secret used to sign/verify admin tokens (change in production!)
ADMIN_SECRET=dev-secret-change-me

# Comma-separated allowed CORS origins
# Use chrome-extension:// to allow all extensions, or specify extension ID
CORS_ORIGINS=http://localhost:5173,chrome-extension://

# Room cleanup: remove inactive rooms after N minutes (0 = never)
ROOM_TTL_MINUTES=120
