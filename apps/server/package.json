    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "@fastify/helmet": "^11.1.1",
    "nanoid": "^3.3.7",
    "uuid": "^9.0.1",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "drizzle-kit": "^0.20.14",
